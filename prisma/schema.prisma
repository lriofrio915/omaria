// OmarIA - Prisma Schema
// RRHH Management System for SG Consulting Group

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum DocumentType {
  JOB_ANALYSIS
  ORGANIGRAM
  FLOWCHART
  MANUAL
  CONTRACT
  POLICY
  PROCEDURE
  OTHER
}

enum DocumentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PayrollStatus {
  PENDING
  PROCESSED
  PAID
  CANCELLED
}

enum ContractType {
  INDEFINITE
  FIXED_TERM
  PART_TIME
  FREELANCE
}

enum CompetencyLevel {
  NONE
  BASIC
  INTERMEDIATE
  ADVANCED
  EXPERT
}

// ─────────────────────────────────────────────
// CORE MODELS
// ─────────────────────────────────────────────

model Company {
  id             String       @id @default(cuid())
  name           String       @unique
  slug           String       @unique
  description    String?
  logoUrl        String?
  primaryColor   String       @default("#1B3D5C")
  secondaryColor String?
  isActive       Boolean      @default(true)
  departments    Department[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("companies")
}

model Department {
  id          String       @id @default(cuid())
  name        String
  description String?
  companyId   String?
  company     Company?     @relation(fields: [companyId], references: [id])
  parentId    String?
  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")
  positions   Position[]
  employees   Employee[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([name, companyId])
  @@map("departments")
}

model Position {
  id               String              @id @default(cuid())
  title            String
  description      String?
  purpose          String?             @db.Text
  responsibilities String[]
  education        String?
  experience       String?
  skills           String[]
  departmentId     String
  department       Department          @relation(fields: [departmentId], references: [id])
  level            Int                 @default(1)
  employees        Employee[]
  competencies     PositionCompetency[]
  jobAnalysis      Document[]          @relation("PositionDocuments")
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@map("positions")
}

model Employee {
  id             String               @id @default(cuid())
  userId         String               @unique
  employeeCode   String               @unique
  firstName      String
  lastName       String
  email          String               @unique
  phone          String?
  whatsapp       String?
  bio            String?              @db.Text
  birthDate      DateTime?
  hireDate       DateTime
  endDate        DateTime?
  contractType   ContractType         @default(INDEFINITE)
  status         EmployeeStatus       @default(ACTIVE)
  salary         Decimal?             @db.Decimal(10, 2)
  departmentId   String
  department     Department           @relation(fields: [departmentId], references: [id])
  positionId     String
  position       Position             @relation(fields: [positionId], references: [id])
  managerId      String?
  manager        Employee?            @relation("EmployeeHierarchy", fields: [managerId], references: [id])
  subordinates   Employee[]           @relation("EmployeeHierarchy")
  documents      Document[]           @relation("EmployeeDocuments")
  payrollRecords PayrollRecord[]
  competencies   EmployeeCompetency[]
  profile        EmployeeProfile?
  personalEmail  String?
  corporateEmail String?
  bloodType      String?
  avatarUrl      String?
  address        String?
  city           String?
  notes          String?
  role           String               @default("EMPLOYEE")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@map("employees")
}

model Competency {
  id                   String               @id @default(cuid())
  name                 String               @unique
  description          String?
  category             String               // "Directiva", "Tecnica", "Blanda"
  positionRequirements PositionCompetency[]
  employeeCompetencies EmployeeCompetency[]
  createdAt            DateTime             @default(now())

  @@map("competencies")
}

model PositionCompetency {
  id            String          @id @default(cuid())
  positionId    String
  position      Position        @relation(fields: [positionId], references: [id], onDelete: Cascade)
  competencyId  String
  competency    Competency      @relation(fields: [competencyId], references: [id])
  requiredLevel CompetencyLevel
  isCritical    Boolean         @default(false)

  @@unique([positionId, competencyId])
  @@map("position_competencies")
}

model EmployeeCompetency {
  id           String          @id @default(cuid())
  employeeId   String
  employee     Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  competencyId String
  competency   Competency      @relation(fields: [competencyId], references: [id])
  currentLevel CompetencyLevel
  assessedAt   DateTime        @default(now())
  notes        String?

  @@unique([employeeId, competencyId])
  @@map("employee_competencies")
}

model Document {
  id           String         @id @default(cuid())
  title        String
  description  String?
  type         DocumentType
  status       DocumentStatus @default(DRAFT)
  fileUrl      String
  fileName     String
  fileSize     Int?
  mimeType     String?
  version      Int            @default(1)
  tags         String[]
  employeeId   String?
  employee     Employee?      @relation("EmployeeDocuments", fields: [employeeId], references: [id])
  positionId   String?
  position     Position?      @relation("PositionDocuments", fields: [positionId], references: [id])
  uploadedById String
  isPublic     Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("documents")
}

model PayrollRecord {
  id             String        @id @default(cuid())
  employeeId     String
  employee       Employee      @relation(fields: [employeeId], references: [id])
  period         String
  periodStart    DateTime
  periodEnd      DateTime
  paymentDate    DateTime?
  grossSalary    Decimal       @db.Decimal(10, 2)
  deductions     Decimal       @default(0) @db.Decimal(10, 2)
  bonuses        Decimal       @default(0) @db.Decimal(10, 2)
  netSalary      Decimal       @db.Decimal(10, 2)
  status         PayrollStatus @default(PENDING)
  receiptUrl     String?
  receiptName    String?
  notes          String?
  processedById  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([employeeId, period])
  @@map("payroll_records")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entity     String
  entityId   String?
  changes    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

model EmployeeProfile {
  id             String                  @id @default(cuid())
  employeeId     String                  @unique
  employee       Employee                @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  headline       String?
  summary        String?                 @db.Text
  publicSlug     String?                 @unique
  isPublic       Boolean                 @default(true)
  linkedinUrl    String?
  websiteUrl     String?
  githubUrl      String?
  cvUrl          String?
  cvFileName     String?
  senescytUrl    String?
  senescytFileName String?
  trackRecordUrl     String?
  trackRecordFileName String?
  trackRecordLink    String?
  education      EmployeeEducation[]
  experience     EmployeeWorkExperience[]
  skills         EmployeeSkill[]
  languages      EmployeeLanguage[]
  certifications EmployeeCertification[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@map("employee_profiles")
}

model EmployeeEducation {
  id          String          @id @default(cuid())
  profileId   String
  profile     EmployeeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  institution String
  degree      String
  field       String
  startYear   Int
  endYear     Int?
  current     Boolean         @default(false)
  description String?
  fileUrl     String?
  fileName    String?
  createdAt   DateTime        @default(now())

  @@map("employee_education")
}

model EmployeeWorkExperience {
  id          String          @id @default(cuid())
  profileId   String
  profile     EmployeeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company     String
  position    String
  location    String?
  startDate   DateTime
  endDate     DateTime?
  current     Boolean         @default(false)
  description String?         @db.Text
  createdAt   DateTime        @default(now())

  @@map("employee_work_experience")
}

model EmployeeSkill {
  id        String          @id @default(cuid())
  profileId String
  profile   EmployeeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  level     Int             @default(3)
  category  String          @default("Técnica")

  @@map("employee_skills")
}

model EmployeeLanguage {
  id        String          @id @default(cuid())
  profileId String
  profile   EmployeeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  language  String
  level     String

  @@map("employee_languages")
}

model EmployeeCertification {
  id            String          @id @default(cuid())
  profileId     String
  profile       EmployeeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name          String
  issuer        String
  issueYear     Int?
  expiryYear    Int?
  credentialUrl String?
  fileUrl       String?
  fileName      String?
  createdAt     DateTime        @default(now())

  @@map("employee_certifications")
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String?
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String      @db.Text
  createdAt DateTime    @default(now())

  @@map("chat_messages")
}
